{
  "manifest_version": 3,
  "name": "Browser Tools",
  "description": "Tools to augment your productivity",
  "version": "1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-palette": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Toggle command palette"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gitlab.com/*/merge_requests/*"
      ],
      "js": [
        "common.js",
        "mr_in_review.js"
      ]
    },
    {
      "matches": [
        "https://gitlab.com/*/merge_requests/new*"
      ],
      "js": [
        "common.js",
        "create_mr.js"
      ]
    },
    {
      "matches": [
        "https://obnewchannel.atlassian.net/browse/*"
      ],
      "js": [
        "common.js",
        "jira_copy_ticket.js"
      ]
    },
    {
      "matches": [
        "https://faturas.portaldasfinancas.gov.pt/resolverListaPendenciasAdquirente.action",
        "https://faturas.portaldasfinancas.gov.pt/resolverListaPendenciasAdquirenteForm.action"
      ],
      "js": [
        "common.js",
        "efatura_weekday.js"
      ]
    },
    {
      "matches": [
        "https://app.seg-social.pt/sso/login*",
        "https://www.seg-social.pt/sso/login*"
      ],
      "js": [
        "common.js",
        "seg_social_login.js"
      ]
    },
    {
      "matches": [
        "https://www.acesso.gov.pt/v2/loginForm*"
      ],
      "js": [
        "common.js",
        "acesso_gov_login.js"
      ]
    },
    {
      "matches": [
        "https://sitfiscal.portaldasfinancas.gov.pt/geral/home*",
        "https://sitfiscal.portaldasfinancas.gov.pt/geral/dashboard*"
      ],
      "js": [
        "common.js",
        "financas_home_shortcuts.js"
      ]
    },
    {
      "matches": [
        "https://www.youtube.com/watch*"
      ],
      "js": [
        "common.js",
        "youtube_summarize.js"
      ]
    },
    {
      "matches": [
        "https://www.seg-social.pt/ptss/pssd/home*"
      ],
      "js": [
        "common.js",
        "seg_social_home.js"
      ]
    },
    {
      "matches": [
        "https://mrocare.pt/request-a-quote/*"
      ],
      "js": [
        "common.js",
        "mrocare_fill_quote.js"
      ]
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "js": [
        "palette_links.js",
        "palette.js"
      ]
    }
  ]
}